DATABASE_URL=sqlite:///./office.db
TICK_SECONDS=3
CORS_ORIGINS=http://localhost:5173
OFFICE_OPEN=09:00
OFFICE_CLOSE=17:00

# Discord bot (see ../jifat/SETUP.md for how to obtain these).
DISCORD_TOKEN=
BOT_COMMAND_PREFIX=!
API_BASE=http://localhost:8000

# Proactive alerts (bonus): channel the bot posts alerts to. Leave empty to disable.
# Enable Discord Developer Mode, right-click the channel -> Copy Channel ID.
ALERT_CHANNEL_ID=
ALERT_POLL_SECONDS=15

# LLM via OpenRouter.
OPENROUTER_API_KEY=
# Use a fast *instruct* model. Avoid "reasoning" models (e.g. nemotron/deepseek-r1/qwq): they leak
# their chain-of-thought into replies. Good picks: meta-llama/llama-3.3-70b-instruct:free,
# google/gemma-4-31b-it:free. A small paid model gives the snappiest, most reliable demo.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
